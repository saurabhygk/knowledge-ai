# PostgreSQL
DATABASE_URL=postgresql://knowledgeai:secret@localhost:5432/knowledgeai

# Redis
REDIS_URL=redis://localhost:6379
REDIS_STREAM=knowledge-ai:document-processing

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-ai-docs
MINIO_SECURE=false

# Embeddings — must match knowledge-processor settings
# Supported: openai | ollama
EMBEDDING_PROVIDER=ollama
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM for answer generation (RAG /ask endpoint)
# Supported: openai | ollama
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3.2
OPENAI_CHAT_MODEL=gpt-4o-mini

# App
LOG_LEVEL=INFO
PORT=8080
