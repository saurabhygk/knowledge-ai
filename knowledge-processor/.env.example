# Copy to .env for local development — never commit .env

# PostgreSQL
DATABASE_URL=postgresql://knowledgeai:secret@localhost:5432/knowledgeai

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-ai-docs
MINIO_SECURE=false

# Embeddings — choose one provider
EMBEDDING_PROVIDER=openai          # openai | ollama
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Chunking defaults (overridable per tenant later)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=recursive        # recursive | element_aware

# Redis Stream config
REDIS_STREAM=knowledge-ai:document-processing
REDIS_CONSUMER_GROUP=processor-group
REDIS_CONSUMER_NAME=processor-1
REDIS_BLOCK_MS=5000
REDIS_BATCH_SIZE=10

# App
LOG_LEVEL=INFO
PORT=8001
